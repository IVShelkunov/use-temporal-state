{
  "name": "use-temporal-state",
  "version": "1.0.0",
  "description": "High-performance temporal state manager (undo/redo) for React and TypeScript.",
  "type": "module",
  "author": "IVShelkunov",
  "license":"MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
